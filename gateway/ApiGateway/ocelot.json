{
  "Routes": [
    {
      "DownstreamPathTemplate": "/api/users",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "userservice",
          "Port": 8080
        }
      ],
      "UpstreamPathTemplate": "/users",
      "UpstreamHttpMethod": [
        "GET",
        "POST",
        "PUT"
      ]
    },
    {
      "DownstreamPathTemplate": "/api/tasks",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "taskservice",
          "Port": 8080
        }
      ],
      "UpstreamPathTemplate": "/tasks",
      "UpstreamHttpMethod": [
        "GET",
        "POST",
        "PUT"
      ]
    },
    {
      "DownstreamPathTemplate": "/api/tasks/{id}/assign",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "taskservice",
          "Port": 8080
        }
      ],
      "UpstreamPathTemplate": "/tasks/{id}/assign",
      "UpstreamHttpMethod": [
        "PUT"
      ]
    }
  ],
  "GlobalConfiguration": {
    "BaseUrl": "http://localhost:8080"
  }
}